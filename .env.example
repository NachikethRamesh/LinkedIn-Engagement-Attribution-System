POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=social_attribution_engine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional fallback only (POSTGRES_* is canonical for local Docker setup):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_attribution_engine

# -----------------------------------------------------------------------------
# LinkedIn official API / org-post integration (optional for future real mode)
# Simulation mode works without these.
# -----------------------------------------------------------------------------
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_CLIENT_ID=<LINKEDIN_CLIENT_ID>
LINKEDIN_CLIENT_SECRET=<LINKEDIN_CLIENT_SECRET>
LINKEDIN_ACCESS_TOKEN=<LINKEDIN_ACCESS_TOKEN>

# Org URL ingestion demo simulation source:
# - fixture_json (default): existing JSON fixtures
# - csv: use prepared CSV rows for a specific post URL
LINKEDIN_ORG_SIMULATION_SOURCE=fixture_json
LINKEDIN_ORG_SIMULATION_CSV=
LINKEDIN_ORG_SIMULATION_CSV_SOURCE=generic
EXA_SIMULATION_CSV_PATH=

# -----------------------------------------------------------------------------
# Gemini comment analysis (for post_comment rows)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=<GEMINI_API_KEY>
GEMINI_COMMENT_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_COMMENT_TIMEOUT_SECONDS=20
GEMINI_ATTRIBUTION_SUMMARY_ENABLED=true
GEMINI_ATTRIBUTION_MODEL=gemini-2.0-flash
GEMINI_ATTRIBUTION_TIMEOUT_SECONDS=12

# -----------------------------------------------------------------------------
# Writeback endpoint URLs (all optional; no live delivery if left empty)
# -----------------------------------------------------------------------------
WRITEBACK_CRM_URL=
WRITEBACK_CLAY_URL=
WRITEBACK_EXA_URL=
WRITEBACK_WEBHOOK_GENERIC_URL=

# -----------------------------------------------------------------------------
# Writeback auth credentials (optional; set when your endpoint requires auth)
# -----------------------------------------------------------------------------
CRM_API_KEY=<CRM_API_KEY>
CLAY_API_KEY=<CLAY_API_KEY>
EXA_API_KEY=<EXA_API_KEY>
# Optional aliases supported:
# WRITEBACK_CRM_API_KEY=
# WRITEBACK_CLAY_API_KEY=
# WRITEBACK_EXA_API_KEY=

# Optional webhook secret header for webhook_generic delivery:
WEBHOOK_GENERIC_SECRET=<WEBHOOK_GENERIC_SECRET>
WEBHOOK_GENERIC_SECRET_HEADER=X-Webhook-Secret

# -----------------------------------------------------------------------------
# Frontend local config (frontend/.env uses this key)
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# n8n workflow variable (not consumed by backend code directly)
# -----------------------------------------------------------------------------
# N8N_NOTIFICATION_WEBHOOK_URL=https://example.com/replace-with-slack-or-email-webhook

# -----------------------------------------------------------------------------
# Demo CRM sync behavior for "Run Identity Resolution"
# -----------------------------------------------------------------------------
DEMO_CRM_ACCOUNTS_CSV=
DEMO_CRM_CONTACTS_CSV=
DEMO_CRM_SYNC_ENABLED=false
