        "jsonBody": "={{ ({ status: 'failed', workflow: $workflow.name, run_id: ($json.run || {}).run_id, error_message: ($json.run || {}).error_message || $json.timeout_reason || 'Pipeline failed', output_metrics_json: ($json.run || {}).output_metrics_json || {} }) }}",
        "options": {}
      }
    },
    {
      "id": "14",
      "name": "Notify Health Failure",
      "type": "n8n-nodes-base.httpRequest",
